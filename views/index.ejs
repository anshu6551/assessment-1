<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Product Management CRUD</title>
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Product Inventory</h2>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addProductModal">Add New Product</button>
        </div>

        <div class="row">
            <% products.forEach(product => { %>
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title"><%= product.name %></h5>
                            <h6 class="text-muted"><%= product.brand %></h6>
                            <p class="card-text text-truncate"><%= product.description %></p>
                            <div class="d-flex justify-content-between">
                                <span class="fw-bold text-primary">$<%= product.price %></span>
                                <span class="badge bg-secondary"><%= product.category %></span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 d-flex gap-2">
                            <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#editModal<%= product._id %>">Edit</button>
                            
                            <form action="/api/v1/products/<%= product._id %>" method="POST" class="flex-grow-1">
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100">Archive</button>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="editModal<%= product._id %>" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header bg-info text-white">
                                <h5 class="modal-title">Edit Product: <%= product.name %></h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <form action="/api/v1/products/update/<%= product._id %>" method="POST">
                                <div class="modal-body">
                                    <input type="text" name="name" value="<%= product.name %>" class="form-control mb-2" required>
                                    <input type="text" name="category" value="<%= product.category %>" class="form-control mb-2" required>
                                    <input type="number" name="price" value="<%= product.price %>" class="form-control mb-2" required>
                                    <textarea name="description" class="form-control" rows="3"><%= product.description %></textarea>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    <button type="submit" class="btn btn-info">Update Changes</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Create New Product</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/api/v1/products" method="POST">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6"><label class="form-label">Name</label><input type="text" name="name" class="form-control" required></div>
                            <div class="col-md-6"><label class="form-label">Category</label><input type="text" name="category" class="form-control" required></div>
                            <div class="col-12"><label class="form-label">Description</label><textarea name="description" class="form-control" rows="2" required></textarea></div>
                            <div class="col-md-6"><label class="form-label">Price ($)</label><input type="number" name="price" class="form-control" required></div>
                            <div class="col-md-6"><label class="form-label">Brand</label><input type="text" name="brand" class="form-control"></div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary">Save Product</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>